<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ログイン | 会計管理システム</title>
  <link rel="icon" href="/favicon.png" type="image/png">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center">
  <div class="w-full max-w-sm">
    <!-- ロゴ -->
    <div class="flex flex-col items-center mb-8">
      <div class="w-16 h-16 bg-indigo-700 rounded-xl flex items-center justify-center mb-4">
        <span class="text-white text-2xl font-bold">MS</span>
      </div>
      <h1 class="text-xl font-bold text-gray-800">会計管理システム</h1>
      <p class="text-sm text-gray-500 mt-1">マスターズスタッフ株式会社</p>
    </div>

    <!-- フォーム -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
      <h2 class="text-lg font-semibold text-gray-700 mb-6">ログイン</h2>

      <div id="error-msg" class="hidden mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg"></div>

      <form id="login-form" onsubmit="doLogin(event)">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">メールアドレス</label>
          <input type="email" id="email" required autocomplete="email"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
            placeholder="example@email.com">
        </div>
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 mb-1">パスワード</label>
          <input type="password" id="password" required autocomplete="current-password"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
            placeholder="パスワードを入力">
        </div>
        <button type="submit" id="submit-btn"
          class="w-full bg-indigo-700 hover:bg-indigo-800 text-white font-semibold py-2 rounded-lg transition-colors text-sm">
          ログイン
        </button>
      </form>
    </div>
  </div>

  <script>
    // すでにログイン済みなら index.html へ
    fetch('/api/me').then(r => { if (r.ok) location.href = '/index.html'; }).catch(() => {});

    async function doLogin(e) {
      e.preventDefault();
      const btn = document.getElementById('submit-btn');
      const errEl = document.getElementById('error-msg');
      btn.disabled = true;
      btn.textContent = 'ログイン中...';
      errEl.classList.add('hidden');

      try {
        const res = await fetch('/api/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: document.getElementById('email').value.trim(),
            password: document.getElementById('password').value,
          }),
        });
        const data = await res.json();
        if (res.ok) {
          location.href = '/index.html';
        } else {
          errEl.textContent = data.error || 'ログインに失敗しました';
          errEl.classList.remove('hidden');
          btn.disabled = false;
          btn.textContent = 'ログイン';
        }
      } catch {
        errEl.textContent = 'ネットワークエラーが発生しました';
        errEl.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = 'ログイン';
      }
    }
  </script>
</body>
</html>
